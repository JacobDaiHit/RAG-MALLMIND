APP_ENV=development
HOST=0.0.0.0
PORT=8000

ARK_API_KEY=
OPENAI_API_KEY=
BASE_URL=
MODEL=
FAST_MODEL=
LLM_TIMEOUT_SECONDS=60

# Global LLM switch.
# true: normal deployment, use LLM features according to runtime mode.
# false: test/offline/load-test mode, disable all LLM features and fall back to local rules.
MALLMIND_LLM_ENABLED=true

# Router LLM concurrency and fallback controls.
RECOMMENDATION_ROUTER_LLM_MAX_CONCURRENCY=2
RECOMMENDATION_ROUTER_LLM_ACQUIRE_TIMEOUT_SECONDS=0.05
RECOMMENDATION_LLM_ROUTER_TIMEOUT_SECONDS=3.0
RECOMMENDATION_ROUTER_LLM_CIRCUIT_FAILURES=5
RECOMMENDATION_ROUTER_LLM_CIRCUIT_COOLDOWN_SECONDS=30

RECOMMENDATION_LLM_PARSE=auto
RECOMMENDATION_LLM_GUIDANCE=false
RECOMMENDATION_STREAM_USE_LLM=false
RECOMMENDATION_ENABLE_MILVUS=false
RECOMMENDATION_RETRIEVAL_TIMEOUT_SECONDS=8
RECOMMENDATION_QUERY_EXPANSION=false
RECOMMENDATION_RAG_POSTPROCESS=true

REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=trad_rag
REDIS_CACHE_TTL_SECONDS=300

DATABASE_URL=

# Session state backend.
# development/test defaults to memory; production should explicitly use redis
# when session continuity across workers or restarts is required.
SESSION_BACKEND=memory
SESSION_TTL_SECONDS=7200
SESSION_MAX_COUNT=500
# Backward-compatible alias used by older local configs/tests.
MAX_IN_MEMORY_SESSIONS=500

MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=embeddings_collection
DENSE_EMBEDDING_DIM=1024

ENABLE_PRODUCT_ADMIN_API=false
ENABLE_LEGACY_CHAT_COMPAT=false
ADMIN_TOKEN=

AUTO_MERGE_ENABLED=true
AUTO_MERGE_THRESHOLD=2
RERANK_MODEL=
RERANK_BINDING_HOST=
RERANK_API_KEY=

EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
DASHSCOPE_API_KEY=
your_dashscope_api_key_here
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=3
EMBEDDING_DEVICE=cpu
BM25_STATE_PATH=

VISION_MODEL=
MULTIMODAL_MODEL=
MAX_ATTACHMENT_ANALYSIS_BYTES=6291456
MAX_ATTACHMENT_TEXT_CHARS=1800
RECOMMENDATION_ENABLE_IMAGE_RETRIEVAL=true
IMAGE_RETRIEVAL_TOP_K=8
