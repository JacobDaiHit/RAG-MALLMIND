APP_ENV=development
HOST=0.0.0.0
PORT=8000

ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_API_KEY=
BASE_URL=https://token.sensenova.cn/v1
MODEL=sensenova-6.7-flash-lite
FAST_MODEL=sensenova-6.7-flash-lite
LLM_TIMEOUT_SECONDS=60

MALLMIND_LLM_PROVIDER=openai_compatible
MALLMIND_LLM_BASE_URL=https://token.sensenova.cn/v1
MALLMIND_LLM_API_KEY=
MALLMIND_LLM_MODEL=sensenova-6.7-flash-lite
MALLMIND_LLM_FAST_MODEL=sensenova-6.7-flash-lite
MALLMIND_LLM_TIMEOUT_SECONDS=30
MALLMIND_ROUTER_MODEL=sensenova-6.7-flash-lite
MALLMIND_PARSE_MODEL=sensenova-6.7-flash-lite
MALLMIND_GUIDANCE_MODEL=sensenova-6.7-flash-lite
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=
DEEPSEEK_FAST_MODEL=
MIMO_API_KEY=
MIMO_BASE_URL=
MIMO_MODEL=
MIMO_FAST_MODEL=

MALLMIND_LLM_ENABLED=true

RECOMMENDATION_ROUTER_LLM_MAX_CONCURRENCY=2
RECOMMENDATION_ROUTER_LLM_ACQUIRE_TIMEOUT_SECONDS=0.5
RECOMMENDATION_LLM_ROUTER_TIMEOUT_SECONDS=20
RECOMMENDATION_ROUTER_LLM_CIRCUIT_FAILURES=5
RECOMMENDATION_ROUTER_LLM_CIRCUIT_COOLDOWN_SECONDS=30

RECOMMENDATION_LLM_PARSE=auto
RECOMMENDATION_LLM_PARSE_TIMEOUT_SECONDS=20

# 先关闭 guidance，避免评估被导购文案 LLM 拖死。
# 等 router / parse / RAG 跑通后，再单独打开测试。
RECOMMENDATION_LLM_GUIDANCE=false
RECOMMENDATION_LLM_GUIDANCE_TIMEOUT_SECONDS=20
RECOMMENDATION_STREAM_USE_LLM=false

# full / rag_only 评估需要打开。
RECOMMENDATION_ENABLE_MILVUS=false
RECOMMENDATION_USE_MILVUS=true
RECOMMENDATION_RETRIEVAL_TIMEOUT_SECONDS=20

# 先关闭 query expansion，避免额外 LLM 调用干扰基础评估。
RECOMMENDATION_QUERY_EXPANSION=false
RECOMMENDATION_RAG_POSTPROCESS=true

# 当前没有配置 PostgreSQL 时，必须先关掉 auto merge。
AUTO_MERGE_ENABLED=false
AUTO_MERGE_THRESHOLD=2
DATABASE_URL=

REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=trad_rag
REDIS_CACHE_TTL_SECONDS=300

SESSION_BACKEND=memory
SESSION_TTL_SECONDS=7200
SESSION_MAX_COUNT=500
MAX_IN_MEMORY_SESSIONS=500

MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=mallmind_product_chunks_qwen_v1
MILVUS_V3_COLLECTION=mallmind_product_evidence_v3
MILVUS_V3_BM25_STATE_PATH=data/bm25_state_v3.json
V3_RETRIEVAL_ENABLED=true
MILVUS_COLLECTION_NAME=mallmind_product_chunks_qwen_v1
MILVUS_TOKEN=

EMBEDDING_PROVIDER=dashscope
# 仅填写本机或部署环境中的新密钥；严禁提交真实值。
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIM=1024

EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
DENSE_EMBEDDING_DIM=1024
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BATCH_SIZE=10
EMBEDDING_TIMEOUT_SECONDS=8
EMBEDDING_MAX_RETRIES=3

RERANK_MODEL=
RERANK_BINDING_HOST=
RERANK_API_KEY=

VISION_MODEL=ep-20260514111645-lmgt2
MULTIMODAL_MODEL=
MAX_ATTACHMENT_ANALYSIS_BYTES=6291456
MAX_ATTACHMENT_TEXT_CHARS=1800
RECOMMENDATION_ENABLE_IMAGE_RETRIEVAL=true
IMAGE_RETRIEVAL_TOP_K=8

ENABLE_PRODUCT_ADMIN_API=false
ENABLE_LEGACY_CHAT_COMPAT=false
ADMIN_TOKEN=

ADMIN_INVITE_CODE=123456
GRADE_MODEL=ep-20260514111645-lmgt2
